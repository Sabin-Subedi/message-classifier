# Path to the trained model artifact (joblib).
MODEL_PATH=models/classifier.joblib

# Path to the metrics JSON written by train.py
METRICS_PATH=models/metrics.json

# Set a non-empty value to require X-API-Key on protected endpoints.
# Leave empty to disable auth (dev only).
API_KEY=

# uvicorn/log level
LOG_LEVEL=INFO

# Maximum number of texts allowed per /predict/batch request
MAX_BATCH_SIZE=100

# Maximum allowed text length (characters)
MAX_TEXT_LENGTH=4000
